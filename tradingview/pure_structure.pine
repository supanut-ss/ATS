//@version=6
strategy(
     title               = "Pure Structure + EMA 200 v6 [Hybrid Trailing]",
     overlay             = true,
     initial_capital     = 10000,
     default_qty_type    = strategy.fixed,
     default_qty_value   = 1,
     commission_type     = strategy.commission.cash_per_contract,
     commission_value    = 0.035,
     slippage            = 3,
     max_lines_count     = 500
 )

// ==========================================
// 1. Inputs
// ==========================================
pivot_length     = input.int(3, title="Pivot Lookback Length", minval=1)
rr_ratio         = input.float(2.0, title="Risk/Reward Ratio (ตามเทรนด์)")
rr_ratio_counter = input.float(1.0, title="Risk/Reward Ratio (สวนเทรนด์)", tooltip="R:R สำหรับไม้ที่สวนเทรนด์หลัก H1 & H4")
sl_buffer        = input.float(1.0, title="เผื่อระยะ SL (ดอลลาร์)")
max_sl           = input.float(20.0, title="Max SL (USD)", tooltip="ระยะ SL สูงสุดไม่เกิน X USD ต่อไม้")
pd_threshold     = input.float(0.618, title="Premium/Discount Fib Threshold", minval=0.1, maxval=0.75, step=0.05,
     tooltip="ระดับที่ราคาต้องย่อตัวเข้ามาเพื่อเข้าออเดอร์ (0.618 = Fib golden ratio)")

// --- Risk Management ---
grp_risk    = "🛡 Risk Management"
risk_mode   = input.string("Fixed Cash", title="Position Sizing Mode", options=["Fixed Contracts", "Fixed Cash", "Percent of Equity"], group=grp_risk)
risk_amount = input.float(12.0, title="Risk Amount (USD or %)", minval=0.01, group=grp_risk)
fixed_qty   = input.float(1.0, title="Fixed Contracts Quantity", minval=0.01, group=grp_risk)

// --- BE & Trailing Stop ---
grp_trail  = "🔒 Trailing Stop"
use_be     = input.bool(true, title="เปิดใช้งาน Breakeven (กันทุน)", group=grp_trail)
be_trigger = input.float(1.0, title="Breakeven Trigger (R)", minval=0.5, step=0.1, group=grp_trail, tooltip="ระยะ R ที่จะเริ่มเลื่อน SL มาบังหน้าทุน")
use_trail  = input.bool(true, title="เปิดใช้งาน Smooth Trailing Stop", group=grp_trail)
trail_dist = input.float(1.0, title="ระยะ Smooth Trailing (หน่วย R)", step=0.1, group=grp_trail, tooltip="ระยะห่างที่ SL จะวิ่งตามราคาสูงสุด/ต่ำสุดแบบต่อเนื่อง")

// --- Trend Filters ---
grp_trend            = "📈 Trend Filters"
use_ema              = input.bool(true, title="เปิดใช้งานตัวกรอง EMA 200 (M5)", group=grp_trend)
ema_length           = input.int(200, title="M5 EMA Length", group=grp_trend)
use_h1_trend         = input.bool(true, title="เปิดใช้งานเทรนด์ H1", group=grp_trend)
h1_ema_len           = input.int(21, title="H1 EMA Length", minval=5, group=grp_trend)
use_h4_trend         = input.bool(false, title="เปิดใช้งานเทรนด์ H4", group=grp_trend)
h4_ema_len           = input.int(21, title="H4 EMA Length", minval=5, group=grp_trend)
filter_counter_trend = input.bool(false, title="บล็อกไม้สวนเทรนด์ทั้งหมด (ไม่เปิดไม้)", group=grp_trend,
     tooltip="หากเปิดใช้: จะห้ามออกไม้สวนเทรนด์เลย (เหมือนเดิม) / หากปิดใช้: สวนเทรนด์ได้แต่เก็บ TP สั้นลง")

// ── Webhook ──
grp_wh        = "🔗 Webhook"
webhook_token = input.string("ats_sec_9f5c4b8e2a1d7f0e3c6b8a9f", "Auth Token", group=grp_wh)

f_n(v) => str.tostring(math.round(v, 2))

f_open(act, ent, sl, tp, sid, vol, rr) =>
    '{"token":"' + webhook_token + '","action":"' + act + '","symbol":"XAUUSD","signal_id":"' + sid + '","entry":' + f_n(ent) + ',"sl":' + f_n(sl) + ',"tp":' + f_n(tp) + ',"volume":' + f_n(vol) + ',"rr":' + str.tostring(rr) + ',"tf":"' + timeframe.period + '","t":' + str.tostring(time) + '}'

f_close(sid, ent, ext, pnl, res) =>
    '{"token":"' + webhook_token + '","action":"CLOSE","symbol":"XAUUSD","signal_id":"' + sid + '","entry":' + f_n(ent) + ',"exit":' + f_n(ext) + ',"pnl":' + str.tostring(pnl) + ',"result":"' + res + '","t":' + str.tostring(time) + '}'

// ==========================================
// 1.5 EMA & Multi-Timeframe Trend
// ==========================================
ema_line = ta.ema(close, ema_length)
plot(use_ema ? ema_line : na, color=color.white, linewidth=2, title="EMA Filter")

// H1 Trend
h1_ema   = request.security(syminfo.tickerid, "60", ta.ema(close, h1_ema_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
h1_close = request.security(syminfo.tickerid, "60", close[1],                      barmerge.gaps_off, barmerge.lookahead_off)
h1_bull  = h1_close > h1_ema
h1_bear  = h1_close < h1_ema

// H4 Trend
h4_ema   = request.security(syminfo.tickerid, "240", ta.ema(close, h4_ema_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
h4_close = request.security(syminfo.tickerid, "240", close[1],                      barmerge.gaps_off, barmerge.lookahead_off)
h4_bull  = h4_close > h4_ema
h4_bear  = h4_close < h4_ema

// [FIXED] ลอจิกตรวจสอบสถานะสวนเทรนด์อย่างแท้จริง
is_counter_long  = (use_h1_trend and h1_bear) or (use_h4_trend and h4_bear)
is_counter_short = (use_h1_trend and h1_bull) or (use_h4_trend and h4_bull)

// [FIXED] เพื่อให้ตัวกรองการเปิดไม้ (Trend Filters) ทำงานได้ถูกต้อง
htf_bull = (not use_h1_trend or h1_bull) and (not use_h4_trend or h4_bull)
htf_bear = (not use_h1_trend or h1_bear) and (not use_h4_trend or h4_bear)

// ==========================================
// 2. Market Structure & Labeling
// ==========================================
ph = ta.pivothigh(high, pivot_length, pivot_length)
pl = ta.pivotlow(low, pivot_length, pivot_length)

var float  last_ph        = na
var float  last_pl        = na
var float  prev_ph        = na
var float  prev_pl        = na
var int    last_ph_bar    = na
var int    last_pl_bar    = na
var int    last_pivot_bar   = na
var float  last_pivot_price = na
var string last_pivot_type  = na
var line   zigzag_line      = na
var int    trend            = 0

if not na(ph)
    prev_ph      := last_ph
    last_ph      := ph
    last_ph_bar  := bar_index - pivot_length
    if last_pivot_type == "L"
        zigzag_line      := line.new(x1=last_pivot_bar, y1=last_pivot_price, x2=last_ph_bar, y2=ph, color=color.new(color.orange, 20), width=2)
        last_pivot_bar   := last_ph_bar
        last_pivot_price := ph
        last_pivot_type  := "H"
    else if last_pivot_type == "H"
        if ph > last_pivot_price
            line.set_x2(zigzag_line, last_ph_bar)
            line.set_y2(zigzag_line, ph)
            last_pivot_bar   := last_ph_bar
            last_pivot_price := ph
    else
        last_pivot_bar   := last_ph_bar
        last_pivot_price := ph
        last_pivot_type  := "H"

if not na(pl)
    prev_pl      := last_pl
    last_pl      := pl
    last_pl_bar  := bar_index - pivot_length
    if last_pivot_type == "H"
        zigzag_line      := line.new(x1=last_pivot_bar, y1=last_pivot_price, x2=last_pl_bar, y2=pl, color=color.new(color.teal, 20), width=2)
        last_pivot_bar   := last_pl_bar
        last_pivot_price := pl
        last_pivot_type  := "L"
    else if last_pivot_type == "L"
        if pl < last_pivot_price
            line.set_x2(zigzag_line, last_pl_bar)
            line.set_y2(zigzag_line, pl)
            last_pivot_bar   := last_pl_bar
            last_pivot_price := pl
    else
        last_pivot_bar   := last_pl_bar
        last_pivot_price := pl
        last_pivot_type  := "L"

// ==========================================
// 3. Break of Structure
// ==========================================
if trend <= 0 and close > last_ph
    trend := 1

if trend >= 0 and close < last_pl
    trend := -1

// ==========================================
// 4. Premium / Discount & PA
// ==========================================
var float swing_high = na
var float swing_low  = na

if trend == 1
    swing_low  := nz(swing_low, last_pl)
    swing_high := math.max(nz(swing_high, high), high)
else if trend == -1
    swing_high := nz(swing_high, last_ph)
    swing_low  := math.min(nz(swing_low, low), low)

if ta.change(trend) != 0
    if trend == 1
        swing_low  := last_pl
        swing_high := high
    else if trend == -1
        swing_high := last_ph
        swing_low  := low

swing_range    = swing_high - swing_low
discount_level = swing_low  + (swing_range * pd_threshold)
premium_level  = swing_high - (swing_range * pd_threshold)

var bool touched_discount = false
var bool touched_premium  = false

// เซ็ต flag เมื่อราคาแตะโซน
if trend == 1 and low <= discount_level
    touched_discount := true

if trend != 1 or strategy.position_size > 0
    touched_discount := false

if trend == -1 and high >= premium_level
    touched_premium := true

if trend != -1 or strategy.position_size > 0
    touched_premium := false

// PA Confirmation
bullish_pa = close[1] < open[1] and close > open
bearish_pa = close[1] > open[1] and close < open

// Trend filter conditions
ema_long_cond  = use_ema ? (close > ema_line) : true
ema_short_cond = use_ema ? (close < ema_line) : true

// If filter_counter_trend is active, we block entries against HTF trend
long_trend_ok  = not filter_counter_trend or not htf_bear
short_trend_ok = not filter_counter_trend or not htf_bull

longCondition  = trend == 1  and touched_discount and bullish_pa and ema_long_cond  and long_trend_ok  and strategy.position_size == 0
shortCondition = trend == -1 and touched_premium  and bearish_pa and ema_short_cond and short_trend_ok and strategy.position_size == 0

// ==========================================
// 5. Execution & Risk Management
// ==========================================
var float  t_entry_long  = na
var float  t_sl_long     = na
var float  t_tp_long     = na
var float  t_risk_long   = na
var float  t_entry_short = na
var float  t_sl_short    = na
var float  t_tp_short    = na
var float  t_risk_short  = na
var string sid_long      = na
var string sid_short     = na

pos_closed_long  = strategy.position_size <= 0 and strategy.position_size[1] > 0
pos_closed_short = strategy.position_size >= 0 and strategy.position_size[1] < 0

is_entering_long  = false
is_entering_short = false

f_calc_qty(risk_dist) =>
    float qty = na
    if risk_dist > 0
        if risk_mode == "Fixed Contracts"
            qty := fixed_qty
        else if risk_mode == "Fixed Cash"
            qty := risk_amount / risk_dist
        else if risk_mode == "Percent of Equity"
            qty := (strategy.equity * (risk_amount / 100.0)) / risk_dist
    qty := math.max(0.01, math.round(qty, 2))
    qty

// [FIXED] กำหนด R:R ให้ตรงกับความเป็นจริง ไม่ผิดเพี้ยนเวลาปิด Filter H1
active_rr_long  = is_counter_long ? rr_ratio_counter : rr_ratio
active_rr_short = is_counter_short ? rr_ratio_counter : rr_ratio

if longCondition
    sl_price = swing_low - sl_buffer
    risk     = close - sl_price
    if risk > 0 and risk <= max_sl
        tp_price         = close + (risk * active_rr_long)
        q                = f_calc_qty(risk)
        strategy.entry("Buy", strategy.long, qty=q)
        t_entry_long     := close
        t_sl_long        := sl_price
        t_tp_long        := tp_price
        t_risk_long      := risk
        s                = str.tostring(time) + "_BUY"
        sid_long         := s
        is_entering_long := true
        alert(f_open("BUY", close, sl_price, tp_price, s, q, active_rr_long), alert.freq_once_per_bar_close)

if shortCondition
    sl_price = swing_high + sl_buffer
    risk     = sl_price - close
    if risk > 0 and risk <= max_sl
        tp_price          = close - (risk * active_rr_short)
        q                 = f_calc_qty(risk)
        strategy.entry("Sell", strategy.short, qty=q)
        t_entry_short     := close
        t_sl_short        := sl_price
        t_tp_short        := tp_price
        t_risk_short      := risk
        s                 = str.tostring(time) + "_SELL"
        sid_short         := s
        is_entering_short := true
        alert(f_open("SELL", close, sl_price, tp_price, s, q, active_rr_short), alert.freq_once_per_bar_close)

// ── [FIXED] Hybrid BE & Smooth Trailing Stop ──
if strategy.position_size > 0 and not na(t_risk_long) and t_risk_long > 0
    ep       = strategy.position_avg_price
    // ใช้ high จับกำไรสูงสุดระหว่างแท่งเทียน
    profit_r = (high - ep) / t_risk_long 
    new_sl   = t_sl_long
    
    // 1. ล็อคหน้าทุน (Breakeven)
    if use_be and profit_r >= be_trigger
        new_sl := math.max(new_sl, ep)
        
    // 2. Smooth Trailing
    if use_trail and profit_r >= be_trigger
        smooth_sl = high - (trail_dist * t_risk_long)
        new_sl := math.max(new_sl, smooth_sl)
        
    t_sl_long := new_sl

if strategy.position_size < 0 and not na(t_risk_short) and t_risk_short > 0
    ep       = strategy.position_avg_price
    // ใช้ low จับกำไรสูงสุดระหว่างแท่งเทียน
    profit_r = (ep - low) / t_risk_short 
    new_sl   = t_sl_short
    
    // 1. ล็อคหน้าทุน (Breakeven)
    if use_be and profit_r >= be_trigger
        new_sl := math.min(new_sl, ep)
        
    // 2. Smooth Trailing
    if use_trail and profit_r >= be_trigger
        smooth_sl = low + (trail_dist * t_risk_short)
        new_sl := math.min(new_sl, smooth_sl)
        
    t_sl_short := new_sl

// ── Exits ──
if strategy.position_size > 0 and not na(t_sl_long) and not na(t_tp_long)
    strategy.exit("Exit Buy", "Buy", stop=t_sl_long, limit=t_tp_long)

if strategy.position_size < 0 and not na(t_sl_short) and not na(t_tp_short)
    strategy.exit("Exit Sell", "Sell", stop=t_sl_short, limit=t_tp_short)

if pos_closed_long and not is_entering_long
    t_entry_long := na
    t_sl_long    := na
    t_tp_long    := na
    t_risk_long  := na
    sid_long     := na

if pos_closed_short and not is_entering_short
    t_entry_short := na
    t_sl_short    := na
    t_tp_short    := na
    t_risk_short  := na
    sid_short     := na

if strategy.closedtrades > nz(strategy.closedtrades[1], 0)
    idx    = strategy.closedtrades - 1
    pnl    = strategy.closedtrades.profit(idx)
    res    = pnl > 0 ? "WIN" : "LOSS"
    ep     = strategy.closedtrades.entry_price(idx)
    xp     = strategy.closedtrades.exit_price(idx)
    is_lng = strategy.closedtrades.size(idx) > 0
    fb     = str.tostring(time) + "_CLOSE"
    cid    = is_lng ? (na(sid_long) ? fb : sid_long) : (na(sid_short) ? fb : sid_short)
    alert(f_close(cid, ep, xp, pnl, res), alert.freq_once_per_bar_close)

// ==========================================
// 6. Webhook Alerts Completed
// ==========================================