//@version=6
strategy(
     title               = "Pure Structure v2 [Liquidity+CHoCH+BOS+FVG/OB]",
     overlay             = true,
     initial_capital     = 100000,
     default_qty_type    = strategy.fixed,
     default_qty_value   = 0.01,
     margin_long         = 0,
     margin_short        = 0,
     commission_type     = strategy.commission.cash_per_contract,
     commission_value    = 0.035,
     slippage            = 3,
     max_lines_count     = 500
 )

// ==========================================
// 1. Inputs
// ==========================================
pivot_length  = input.int(3,  title="Pivot Lookback Length", minval=1)
sl_buffer     = input.float(1.0, title="SL Buffer (USD)")
max_sl_pips   = input.int(1000,  title="Max Structural SL (Pips/Points)")
pd_threshold  = input.float(0.618, title="Premium/Discount Fib Threshold", minval=0.1, maxval=0.75, step=0.05)

grp_entry    = "== Entry Logic =="
entry_mode   = input.string("Discount/Premium Only (Original 54% WR)", title="Entry Zone Mode", options=["Discount/Premium Only (Original 54% WR)", "Any FVG/OB (High Frequency)", "FVG/OB Inside Discount/Premium (Strict ICT)"], group=grp_entry)
use_zone_filter = input.bool(true, title="Enable Zone Filter", group=grp_entry, tooltip="ปิด = ไม่ต้องรอ pullback ถึง Discount/Premium zone เข้าไม้ทันที่ trend + PA ตรง (เพิ่ม frequency มาก) | ใช้เพื่อ diagnose หาจุด block)")

// --- Fixed Scalping SL ---
grp_scalp    = "== Scalping Risk =="
use_fixed_sl = input.bool(true, title="Use Fixed SL instead of Structure", group=grp_scalp, tooltip="ใช้ SL คงที่สำหรับสายสั้น แทนการอิง Swing Low/High")
fixed_sl_pips= input.int(500, title="Fixed SL (Points/Pips)", group=grp_scalp, tooltip="500 point = $5.00 ระยะตัดขาดทุนจากจุดเข้า (เช่น Entry 4000 -> SL 3995)")

// --- M5 Anti Fake-PA ---
grp_pa       = "== M5 Anti Fake-PA =="
pa_body_min  = input.float(0.35, title="Min Body Ratio (0.0–1.0)",   minval=0.1, maxval=0.9, step=0.05, group=grp_pa, tooltip="body ของแท่ง PA ต้องใหญ่กว่า X% ของ range | 0.35=35% เหมาะสำหรับ M5 XAUUSD")
pa_wick_max  = input.float(0.60, title="Max Wick Ratio (0.0–1.0)",   minval=0.0, maxval=0.9, step=0.05, group=grp_pa, tooltip="wick ด้านที่สวนทางต้องไม่เกิน X% | 0.60=60% ป้องกัน rejection candle เขียวจัด")
pa_close_min = input.float(0.45, title="Min Close Position (0.0–1.0)",minval=0.1, maxval=0.9, step=0.05, group=grp_pa, tooltip="close ต้องอยู่ในช่วงบน/ล่าง X% ของ range | 0.45=45% เหมาะสำหรับ M5 XAUUSD")
pa_engulf    = input.bool(false, title="Require Engulfing Close",                              group=grp_pa, tooltip="bullish: close ต้องปิดเหนือ open[1] | เปิด = เข้มสุดบน M5")
bos_max_bars   = input.int(3,    title="Pending BOS Expiry (Bars)",   minval=1, maxval=10,  group=grp_pa, tooltip="Pending BOS จะถูกยกเลิกอัตโนมัติถ้าไม่ยืนยันภายใน N bar")
choch_max_bars = input.int(20,   title="CHoCH Block Expiry (Bars)",   minval=5, maxval=100, group=grp_pa, tooltip="CHoCH flag จะหมดอายุอัตโนมัติหลัง N bar (M5: 20 bar = 100นาที)")

// --- Debug ---
grp_debug      = "== Debug =="
show_debug     = input.bool(true,  title="Show Debug Table",    group=grp_debug, tooltip="ตาราง real-time มุมขวาบน")
test_mode      = input.bool(false, title="[TEST] Bypass All Filters", group=grp_debug, tooltip="เปิด = เข้าไม้ทันทีที่ trend==1/-1 โดยไม่ต้องมี PA/Zone/EMA/CHoCH | ใช้วินิจฉัยว่า BOS/trend ทำงานหรือเปล่า")
show_bar_debug = input.bool(false, title="[TEST] Show Bar Labels",  group=grp_debug, tooltip="แสดง label ทุก bar ว่า trend เป็นอะไร + PA ตรงไหม (เปิดให้ zoom เข้าไปดูบนกราฟ)")

// --- Position Sizing ---
grp_risk  = "== Position Sizing =="
fixed_lot = input.float(0.05, title="Fixed Lot (0.05)", minval=0.01, step=0.01, group=grp_risk)

// --- Scaled TP/BE/Trail ---
grp_exit    = "== Exit Management =="
be_pips     = input.int(500,   title="Breakeven at (Points)", group=grp_exit,
              tooltip="เมื่อกำไรถึง $5.00 (500 point) ให้ย้าย SL มาที่ Entry (กันหน้าทุน)")
trail1_pips = input.int(1000,  title="Trail Level1 trigger (Points)", group=grp_exit,
              tooltip="เมื่อกำไรถึง $10.00 (1000 point) ให้เริ่ม Trailing SL")
lock1_pips  = input.int(500,   title="Trail Level1 lock offset (Points)", group=grp_exit,
              tooltip="ล็อกกำไรขั้นต่ำ $5.00 (500 point) เมื่อถึง Trail Level1")
tp_pips     = input.int(2000,  title="Hard TP (Points from entry)", group=grp_exit,
              tooltip="TP อัตโนมัติที่ $20.00 (2000 point) จากจุดเข้า (เช่น Entry 4000 -> TP 4020)")

// --- Trend Filters ---
grp_trend            = "== Trend Filters =="
use_ema              = input.bool(false, title="EMA 200 Filter",              group=grp_trend, tooltip="\u0e1bิด default — H1+H4 EMA กรองทิศทางอยู่แล้ว | EMA200 M5 ขยับช้า ประอัพต่อ scalping")
ema_length           = input.int(200,    title="EMA Length",                 group=grp_trend)
ema_buffer_pips      = input.int(50,     title="EMA Buffer (pips tolerance)",group=grp_trend, tooltip="ถ้าเปิด EMA200 filter ให้เพิ่ม buffer นี้เพื่อไม่ให้ EMA block เมื่อราคาอยู่ใกล้ EMA มาก (50 pip = $0.05 XAUUSD)")
use_h1_trend         = input.bool(true,  title="H1 EMA Filter",              group=grp_trend)
h1_ema_len           = input.int(21,     title="H1 EMA Length",              minval=5, group=grp_trend)
use_h4_trend         = input.bool(true,  title="H4 EMA Filter",              group=grp_trend)
h4_ema_len           = input.int(21,     title="H4 EMA Length",              minval=5, group=grp_trend)
filter_counter_trend = input.bool(false, title="Block Counter-Trend trades", group=grp_trend)

// --- News & Volume Filters ---
grp_news_vol       = "== News & Volume Filters =="
use_news_filter    = input.bool(false, title="Enable News Filter", group=grp_news_vol, tooltip="งดเข้าไม้ในช่วงเวลาที่มีข่าวสำคัญ")
news_session       = input.session("1300-1400,1930-2030:23456", title="News Block Session (UTC)", group=grp_news_vol, tooltip="เวลาที่จะงดเข้าเทรด (รูปแบบ hhmm-hhmm:days โดย 2-6 คือ จันทร์-ศุกร์, คั่นด้วยลูกน้ำได้)")
news_timezone      = input.string("UTC", title="News Timezone", options=["UTC", "America/New_York", "Asia/Bangkok", "Exchange"], group=grp_news_vol)

use_vol_filter     = input.bool(false, title="Enable Volume Spike Filter", group=grp_news_vol, tooltip="ปิด default — XAUUSD หลายเบรกเกอร์ไม่มีข้อมูล Volume ที่เชื่อถือได้ | เปิดถ้าใช้กับ Futures หรือ Stock")
vol_spike_mult     = input.float(2.0, title="Volume Spike Multiplier", minval=1.1, step=0.1, group=grp_news_vol, tooltip="จำนวนเท่าของ Volume เฉลี่ยที่ถือว่าเป็น Volume Spike")
vol_sma_len        = input.int(20, title="Volume SMA Length", minval=5, group=grp_news_vol, tooltip="จำนวนแท่งเทียนที่ใช้อ้างอิงหาค่าเฉลี่ย Volume")
vol_spike_lookback = input.int(3, title="Block Duration (Bars)", minval=1, group=grp_news_vol, tooltip="จำนวนแท่งเทียนที่จะงดเข้าเทรดหลังจากเกิด Volume Spike (1 = เฉพาะแท่งที่เกิด, 3 = แท่งที่เกิด + 2 แท่งถัดไป)")

// --- Sideway & Range Filters ---
grp_sideway        = "== Sideway & Range Filters =="
use_adx_filter     = input.bool(true,  title="Enable ADX Trend Filter",       group=grp_sideway, tooltip="กรองช่วงตลาด Sideway ไร้ทิศทาง (ADX < Threshold จะงดเข้าไม้เพื่อลด False Breakout & Whipsaw)")
adx_len            = input.int(14,     title="ADX Lookback Length",           minval=5, group=grp_sideway)
adx_min_threshold  = input.float(20.0, title="Min ADX Threshold",            minval=10.0, maxval=40.0, step=1.0, group=grp_sideway, tooltip="ถ้า ADX น้อยกว่าค่านี้ (เช่น 20.0) แสดงว่าตลาดเป็น Sideway จะบล็อกการเข้าไม้เพื่อลด Drawdown")

use_chop_filter    = input.bool(false, title="Enable Choppiness Index Filter", group=grp_sideway, tooltip="กรองช่วงตลาดแกว่งตัวไร้ทิศทาง (CHOP > Threshold จะงดเข้าเทรด)")
chop_len           = input.int(14,     title="Choppiness Length",            minval=5, group=grp_sideway)
chop_max_threshold = input.float(60.0, title="Max CHOP Threshold (0-100)",     minval=40.0, maxval=80.0, step=1.0, group=grp_sideway, tooltip="ค่า CHOP ยิ่งสูง (>55-60) แสดงว่าราคาแกว่งตัวผันผวนไร้เทรนด์")

use_atr_filter     = input.bool(false, title="Enable ATR Volatility Squeeze Filter", group=grp_sideway, tooltip="งดเทรดช่วงสภาวะราคาซบเซา Volatility ต่ำผิดปกติ")
atr_min_ratio      = input.float(0.80, title="Min ATR Ratio vs SMA(50)",      minval=0.5, maxval=1.5, step=0.05, group=grp_sideway, tooltip="ATR(14) ต้องไม่ต่ำกว่า X% ของ ATR SMA(50)")

// -- Webhook --
grp_wh        = "== Webhook =="
webhook_token = input.string("ats_sec_9f5c4b8e2a1d7f0e3c6b8a9f", "Auth Token", group=grp_wh)

// ==========================================
// Helpers
// ==========================================
f_n(v) => str.tostring(math.round(v, 2))

f_open(act, ent, sl, tp, sid, vol, be, t1, t1l, tpp) =>
    '{"token":"' + webhook_token + '","action":"' + act + '","symbol":"XAUUSD","signal_id":"' + sid + '","entry":' + f_n(ent) + ',"sl":' + f_n(sl) + ',"tp":' + f_n(tp) + ',"volume":' + f_n(vol) + ',"be_pips":' + str.tostring(be) + ',"trail1_pips":' + str.tostring(t1) + ',"lock1_pips":' + str.tostring(t1l) + ',"tp_pips":' + str.tostring(tpp) + ',"tf":"' + timeframe.period + '","t":' + str.tostring(time) + '}'

f_close(sid, ent, ext, pnl, res) =>
    '{"token":"' + webhook_token + '","action":"CLOSE","symbol":"XAUUSD","signal_id":"' + sid + '","entry":' + f_n(ent) + ',"exit":' + f_n(ext) + ',"pnl":' + str.tostring(pnl) + ',"result":"' + res + '","t":' + str.tostring(time) + '}'

// ==========================================
// EMA & Multi-Timeframe Trend
// ==========================================
ema_line = ta.ema(close, ema_length)
plot(use_ema ? ema_line : na, color=color.white, linewidth=2, title="EMA Filter")

h1_ema   = request.security(syminfo.tickerid, "60",  ta.ema(close, h1_ema_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
h1_close = request.security(syminfo.tickerid, "60",  close[1],                      barmerge.gaps_off, barmerge.lookahead_off)
h4_ema   = request.security(syminfo.tickerid, "240", ta.ema(close, h4_ema_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
h4_close = request.security(syminfo.tickerid, "240", close[1],                      barmerge.gaps_off, barmerge.lookahead_off)

h1_bull = h1_close > h1_ema
h1_bear = h1_close < h1_ema
h4_bull = h4_close > h4_ema
h4_bear = h4_close < h4_ema

is_counter_long  = (use_h1_trend and h1_bear) or (use_h4_trend and h4_bear)
is_counter_short = (use_h1_trend and h1_bull) or (use_h4_trend and h4_bull)
htf_bull = (not use_h1_trend or h1_bull) and (not use_h4_trend or h4_bull)
htf_bear = (not use_h1_trend or h1_bear) and (not use_h4_trend or h4_bear)

// ==========================================
// Market Structure (Pivot High/Low + ZigZag)
// ==========================================
ph = ta.pivothigh(high, pivot_length, pivot_length)
pl = ta.pivotlow(low,   pivot_length, pivot_length)

var float  last_ph        = na
var float  last_pl        = na
var float  prev_ph        = na
var float  prev_pl        = na
var int    last_ph_bar    = na
var int    last_pl_bar    = na
var int    last_pivot_bar   = na
var float  last_pivot_price = na
var string last_pivot_type  = na
var line   zigzag_line      = na
var int    trend            = 0

// CHoCH flags + bar tracker (สำหรับ auto-expiry)
var bool choch_bull     = false
var bool choch_bear     = false
var int  choch_bull_bar = 0
var int  choch_bear_bar = 0

// [FIX3] Pending BOS flags — ต้องยืนยัน 2 bar จึงเปลี่ยน trend + expiry counter (M5)
var bool pending_bos_bull  = false
var bool pending_bos_bear  = false
var int  bos_bull_bar      = 0     // bar_index ที่เริ่ม pending bull
var int  bos_bear_bar      = 0     // bar_index ที่เริ่ม pending bear

if not na(ph)
    prev_ph     := last_ph
    last_ph     := ph
    last_ph_bar := bar_index - pivot_length
    // CHoCH Bear: new PH < prev PH in uptrend (trend change signal)
    if trend == 1 and not na(prev_ph) and last_ph < prev_ph
        choch_bear     := true
        choch_bear_bar := last_ph_bar  // บันทึกเวลาที่ CHoCH เกิด
        label.new(last_ph_bar, ph, "CHoCH", color=color.new(color.red,20), textcolor=color.white, size=size.small, style=label.style_label_down)
    if last_pivot_type == "L"
        zigzag_line     := line.new(x1=last_pivot_bar, y1=last_pivot_price, x2=last_ph_bar, y2=ph, color=color.new(color.orange,20), width=2)
        last_pivot_bar  := last_ph_bar
        last_pivot_price := ph
        last_pivot_type := "H"
    else if last_pivot_type == "H"
        if ph > last_pivot_price
            line.set_x2(zigzag_line, last_ph_bar)
            line.set_y2(zigzag_line, ph)
            last_pivot_bar  := last_ph_bar
            last_pivot_price := ph
    else
        last_pivot_bar  := last_ph_bar
        last_pivot_price := ph
        last_pivot_type := "H"

if not na(pl)
    prev_pl     := last_pl
    last_pl     := pl
    last_pl_bar := bar_index - pivot_length
    // CHoCH Bull: new PL > prev PL in downtrend (trend change signal)
    if trend == -1 and not na(prev_pl) and last_pl > prev_pl
        choch_bull     := true
        choch_bull_bar := last_pl_bar  // บันทึกเวลาที่ CHoCH เกิด
        label.new(last_pl_bar, pl, "CHoCH", color=color.new(color.green,20), textcolor=color.white, size=size.small, style=label.style_label_up)
    if last_pivot_type == "H"
        zigzag_line     := line.new(x1=last_pivot_bar, y1=last_pivot_price, x2=last_pl_bar, y2=pl, color=color.new(color.teal,20), width=2)
        last_pivot_bar  := last_pl_bar
        last_pivot_price := pl
        last_pivot_type := "L"
    else if last_pivot_type == "L"
        if pl < last_pivot_price
            line.set_x2(zigzag_line, last_pl_bar)
            line.set_y2(zigzag_line, pl)
            last_pivot_bar  := last_pl_bar
            last_pivot_price := pl
    else
        last_pivot_bar  := last_pl_bar
        last_pivot_price := pl
        last_pivot_type := "L"

// ==========================================
// BOS (Break of Structure) — [FIX3] ต้องยืนยัน 2 แท่งติดต่อกัน
// ==========================================
// [CHoCH Auto-Expiry] ป้องกัน flag ค้างตลอดกาล — หมดอายุหลัง choch_max_bars bar
if choch_bear and (bar_index - choch_bear_bar) >= choch_max_bars
    choch_bear := false  // หมดอายุ — เปิด Long ได้อีกครั้ง

if choch_bull and (bar_index - choch_bull_bar) >= choch_max_bars
    choch_bull := false  // หมดอายุ — เปิด Short ได้อีกครั้ง

// แท่งแรก: ตั้ง pending flag + บันทึก bar_index
if trend <= 0 and close > last_ph and not pending_bos_bull
    pending_bos_bull := true
    bos_bull_bar     := bar_index
    pending_bos_bear := false

if trend >= 0 and close < last_pl and not pending_bos_bear
    pending_bos_bear := true
    bos_bear_bar     := bar_index
    pending_bos_bull := false

// [M5 FIX] Expiry: ยกเลิก pending BOS ถ้าเกิน bos_max_bars bar แล้วยังไม่ยืนยัน
if pending_bos_bull and (bar_index - bos_bull_bar) >= bos_max_bars
    pending_bos_bull := false  // หมดอายุ — False BOS

if pending_bos_bear and (bar_index - bos_bear_bar) >= bos_max_bars
    pending_bos_bear := false  // หมดอายุ — False BOS

// แท่งที่สอง (หรือมากกว่า): ยืนยัน BOS จริง
if pending_bos_bull and close > last_ph
    trend            := 1
    choch_bear       := false
    pending_bos_bull := false
    label.new(bar_index, high, "BOS▲", color=color.new(color.blue,20), textcolor=color.white, style=label.style_label_up, size=size.small)
else if pending_bos_bull and close <= last_ph
    pending_bos_bull := false  // Closed below again — False BOS

if pending_bos_bear and close < last_pl
    trend            := -1
    choch_bull       := false
    pending_bos_bear := false
    label.new(bar_index, low, "BOS▼", color=color.new(color.red,20), textcolor=color.white, style=label.style_label_down, size=size.small)
else if pending_bos_bear and close >= last_pl
    pending_bos_bear := false  // Closed above again — False BOS

// ==========================================
// Swing High/Low boundaries
// ==========================================
var float swing_high = na
var float swing_low  = na

if trend == 1
    swing_low  := nz(swing_low, last_pl)
    swing_high := math.max(nz(swing_high, high), high)
else if trend == -1
    swing_high := nz(swing_high, last_ph)
    swing_low  := math.min(nz(swing_low, low), low)

if ta.change(trend) != 0
    if trend == 1
        swing_low  := last_pl
        swing_high := high
    else if trend == -1
        swing_high := last_ph
        swing_low  := low

// ==========================================
// Premium / Discount zones
// ==========================================
swing_range    = swing_high - swing_low
discount_level = swing_low  + (swing_range * pd_threshold)
premium_level  = swing_high - (swing_range * pd_threshold)

var bool touched_discount = false
var bool touched_premium  = false

// [BUGFIX] Mark FIRST, reset after — ป้องกัน zone ถูก reset บน bar เดียวกับที่เริ่มตั้ง
// Step 1: Mark zone as touched FIRST
if trend == 1 and low <= discount_level
    touched_discount := true
if trend == -1 and high >= premium_level
    touched_premium  := true

// Step 2: Reset when conditions no longer valid
if trend != 1 or strategy.position_size != 0
    touched_discount := false
if trend != -1 or strategy.position_size != 0
    touched_premium  := false

// ==========================================
// FVG Detection (Fair Value Gap)
// ==========================================
// Bullish FVG: high[2] < low[0]
float bull_fvg_low  = high[2] < low[0] ? high[2] : na
float bull_fvg_high = high[2] < low[0] ? low[0]  : na

// Bearish FVG: low[2] > high[0]
float bear_fvg_low  = low[2] > high[0] ? high[0] : na
float bear_fvg_high = low[2] > high[0] ? low[2]  : na

var float last_bull_fvg_l = na
var float last_bull_fvg_h = na
var float last_bear_fvg_l = na
var float last_bear_fvg_h = na

if not na(bull_fvg_low) and trend == 1
    last_bull_fvg_l := bull_fvg_low
    last_bull_fvg_h := bull_fvg_high
    box.new(bar_index-2, bull_fvg_high, bar_index, bull_fvg_low, bgcolor=color.new(color.green,85), border_color=color.new(color.green,50))

if not na(bear_fvg_low) and trend == -1
    last_bear_fvg_l := bear_fvg_low
    last_bear_fvg_h := bear_fvg_high
    box.new(bar_index-2, bear_fvg_high, bar_index, bear_fvg_low, bgcolor=color.new(color.red,85), border_color=color.new(color.red,50))

// [FIX4] FVG Invalidation — ถ้าราคาปิดทะลุผ่าน FVG ไปอีกด้านแสดงว่าถูก fill แล้ว ให้ reset
if not na(last_bull_fvg_l) and close < last_bull_fvg_l
    last_bull_fvg_l := na
    last_bull_fvg_h := na

if not na(last_bear_fvg_h) and close > last_bear_fvg_h
    last_bear_fvg_l := na
    last_bear_fvg_h := na

// FVG touch
in_bull_fvg = not na(last_bull_fvg_l) and low <= last_bull_fvg_h and high >= last_bull_fvg_l
in_bear_fvg = not na(last_bear_fvg_l) and low <= last_bear_fvg_h and high >= last_bear_fvg_l

// ==========================================
// Order Block (OB) Detection
// ==========================================
// Bullish OB: bearish candle before impulse bullish candle (close > high of -3 bar)
bull_ob_cond = close[2] < open[2] and close[0] > open[0] and close[0] > high[2]
bear_ob_cond = close[2] > open[2] and close[0] < open[0] and close[0] < low[2]

var float bull_ob_l = na
var float bull_ob_h = na
var float bear_ob_l = na
var float bear_ob_h = na

if bull_ob_cond and trend == 1
    bull_ob_l := low[2]
    bull_ob_h := high[2]
    box.new(bar_index-2, high[2], bar_index, low[2], bgcolor=color.new(color.lime,80), border_color=color.new(color.lime,40))

if bear_ob_cond and trend == -1
    bear_ob_l := low[2]
    bear_ob_h := high[2]
    box.new(bar_index-2, high[2], bar_index, low[2], bgcolor=color.new(color.orange,80), border_color=color.new(color.orange,40))

in_bull_ob = not na(bull_ob_l) and low <= bull_ob_h and high >= bull_ob_l
in_bear_ob = not na(bear_ob_l) and low <= bear_ob_h and high >= bear_ob_l

// ==========================================
// Liquidity Sweep Detection
// ==========================================
// Bullish sweep: price dips below prev swing low (liquidity grab) then closes above it
liq_bull_sweep = low < last_pl[1] and close > last_pl[1]
liq_bear_sweep = high > last_ph[1] and close < last_ph[1]

if liq_bull_sweep and trend == 1
    label.new(bar_index, low, "LIQ↑", color=color.new(color.aqua,20), textcolor=color.white, size=size.tiny, style=label.style_label_up)
if liq_bear_sweep and trend == -1
    label.new(bar_index, high, "LIQ↓", color=color.new(color.fuchsia,20), textcolor=color.white, size=size.tiny, style=label.style_label_down)

// ==========================================
// PA Confirmation — [M5 ANTI FAKE-PA] 4 ชั้นป้องกัน
// ==========================================
bullish_pa_raw = close[1] < open[1] and close > open
bearish_pa_raw = close[1] > open[1] and close < open

// --- ค่าพื้นฐานแท่ง PA ปัจจุบัน ---
bull_body  = close - open
bull_range = high - low
bear_body  = open - close
bear_range = high - low

// [LAYER 1] Body Ratio — body ต้องใหญ่กว่า pa_body_min% ของ range (กรอง doji)
bull_body_ratio = bull_range > 0 ? bull_body / bull_range : 0.0
bear_body_ratio = bear_range > 0 ? bear_body / bear_range : 0.0

// [LAYER 2] Wick Rejection Filter — wick ด้านสวนทางห้ามยาวเกิน pa_wick_max%
// bullish: ห้าม upper wick ยาว (rejection ด้านบน = แรงขายยังแรง)
// bearish: ห้าม lower wick ยาว (rejection ด้านล่าง = แรงซื้อยังแรง)
bull_upper_wick   = high - close
bear_lower_wick   = close - low
bull_wick_ratio   = bull_range > 0 ? bull_upper_wick / bull_range : 1.0
bear_wick_ratio   = bear_range > 0 ? bear_lower_wick / bear_range : 1.0

// [LAYER 3] Close Position — close ต้องอยู่ใน pa_close_min% บน/ล่างของ range
// bullish: (close-low)/range >= pa_close_min  → close ใกล้ top
// bearish: (high-close)/range >= pa_close_min → close ใกล้ bottom
bull_close_pos = bull_range > 0 ? (close - low)  / bull_range : 0.0
bear_close_pos = bear_range > 0 ? (high - close) / bear_range : 0.0

// [LAYER 4] Engulfing Close — close ต้องทะลุ open ของ bar ก่อนหน้า (body engulfing)
// bullish: close > open[1] (ปิดเหนือ open แท่ง bearish ก่อนหน้า)
// bearish: close < open[1] (ปิดต่ำกว่า open แท่ง bullish ก่อนหน้า)
bull_engulf = not pa_engulf or (close > open[1])
bear_engulf = not pa_engulf or (close < open[1])

// รวมทุกชั้น
bullish_pa = bullish_pa_raw
           and bull_body_ratio >= pa_body_min
           and bull_wick_ratio  <= pa_wick_max
           and bull_close_pos  >= pa_close_min
           and bull_engulf

bearish_pa = bearish_pa_raw
           and bear_body_ratio >= pa_body_min
           and bear_wick_ratio  <= pa_wick_max
           and bear_close_pos  >= pa_close_min
           and bear_engulf

// ==========================================
// EMA & Trend filter
// ==========================================
ema_buf       = ema_buffer_pips * syminfo.mintick
// Buffer: Long แค่ต้องปิดอยู่เหนือ EMA - buffer, Short แค่ต้องปิดอยู่ต่ำกว่า EMA + buffer
ema_long_cond  = use_ema ? (close > ema_line - ema_buf) : true
ema_short_cond = use_ema ? (close < ema_line + ema_buf) : true
long_trend_ok  = not filter_counter_trend or not htf_bear
short_trend_ok = not filter_counter_trend or not htf_bull

// ==========================================
// Zone Confirmation
// ==========================================
bool zone_bull = false
bool zone_bear = false

if not use_zone_filter
    // Zone filter ปิดอยู่ — เข้าไม้ทันที่ trend + PA ตรง
    zone_bull := true
    zone_bear := true
else if entry_mode == "Discount/Premium Only (Original 54% WR)"
    zone_bull := touched_discount
    zone_bear := touched_premium
else if entry_mode == "Any FVG/OB (High Frequency)"
    zone_bull := in_bull_fvg or in_bull_ob or touched_discount
    zone_bear := in_bear_fvg or in_bear_ob or touched_premium
else if entry_mode == "FVG/OB Inside Discount/Premium (Strict ICT)"
    zone_bull := (in_bull_fvg or in_bull_ob) and touched_discount
    zone_bear := (in_bear_fvg or in_bear_ob) and touched_premium

// ==========================================
// News & Volume Filter Logic
// ==========================================
// News & Volume Filter Logic
// ==========================================
is_news_time = use_news_filter and not na(time(timeframe.period, news_session, news_timezone))

vol_sma = ta.sma(volume, vol_sma_len)
is_volume_spike = use_vol_filter and not na(volume) and not na(vol_sma) and vol_sma > 0 and volume > (vol_sma * vol_spike_mult)
is_volume_blocked = false
if use_vol_filter
    is_volume_blocked := not na(ta.barssince(is_volume_spike)) and ta.barssince(is_volume_spike) < vol_spike_lookback

filter_blocked = is_news_time or is_volume_blocked

// Visuals for News & Volume Filters
bgcolor(is_news_time ? color.new(color.purple, 92) : na, title="News Block Active")
bgcolor(is_volume_blocked ? color.new(color.orange, 92) : na, title="Volume Spike Block Active")

// ==========================================
// Sideway & Range Filter Calculations
// ==========================================
// 1. ADX Filter (Average Directional Index)
[_, _, adx_val] = ta.dmi(adx_len, adx_len)
adx_ok = not use_adx_filter or (not na(adx_val) and adx_val >= adx_min_threshold)

// 2. Choppiness Index Filter
chop_atr_sum = math.sum(ta.atr(1), chop_len)
chop_high_low_diff = ta.highest(high, chop_len) - ta.lowest(low, chop_len)
chop_val = chop_high_low_diff > 0 ? 100.0 * math.log10(chop_atr_sum / chop_high_low_diff) / math.log10(chop_len) : 100.0
chop_ok = not use_chop_filter or (not na(chop_val) and chop_val <= chop_max_threshold)

// 3. ATR Volatility Ratio Filter
atr_14 = ta.atr(14)
atr_sma_50 = ta.sma(atr_14, 50)
atr_ratio = not na(atr_sma_50) and atr_sma_50 > 0 ? (atr_14 / atr_sma_50) : 1.0
atr_ok = not use_atr_filter or atr_ratio >= atr_min_ratio

// Sideway Blocked Flag
sideway_blocked = (use_adx_filter and not adx_ok) or (use_chop_filter and not chop_ok) or (use_atr_filter and not atr_ok)

// Visual for Sideway Block
bgcolor(sideway_blocked ? color.new(color.blue, 94) : na, title="Sideway Filter Block Active")

// ==========================================
// Final Entry Conditions
// ==========================================
// ตรวจสอบ trend เปลี่ยนบน bar นี้
trend_turned_bull = ta.change(trend) != 0 and trend == 1
trend_turned_bear = ta.change(trend) != 0 and trend == -1

bool longCondition  = false
bool shortCondition = false

if test_mode
    // [TEST MODE] เข้าทุก bar ที่ trend == 1/-1 (ไม่ต้องรอ PA/Zone)
    // ถ้ายังไม่ออก = BOS/trend ไม่ทำงาน ไม่ใช่ filter ปัญหา
    longCondition  := trend == 1  and strategy.position_size == 0
    shortCondition := trend == -1 and strategy.position_size == 0
else
    // Normal mode: trend + PA + optional guards
    _long_base  = trend == 1  and bullish_pa and strategy.position_size == 0
    _short_base = trend == -1 and bearish_pa and strategy.position_size == 0
    // Zone filter (optional)
    _long_zone  = use_zone_filter ? zone_bull : true
    _short_zone = use_zone_filter ? zone_bear : true
    // EMA filter (optional, default OFF)
    _long_ema   = ema_long_cond
    _short_ema  = ema_short_cond
    // CHoCH guard (optional)
    _long_choch  = not choch_bear
    _short_choch = not choch_bull

    longCondition  := _long_base  and _long_zone  and _long_ema  and long_trend_ok  and not filter_blocked and not sideway_blocked and _long_choch
    shortCondition := _short_base and _short_zone and _short_ema and short_trend_ok and not filter_blocked and not sideway_blocked and _short_choch

// Bar labels สำหรับ diagnose (เปิดด้วย show_bar_debug)
if show_bar_debug
    _t = trend == 1 ? "Bull" : trend == -1 ? "Bear" : "—"
    _pa_l = bullish_pa ? "bPA✓" : bullish_pa_raw ? "bPA✗f" : ""
    _pa_s = bearish_pa ? "sPA✓" : bearish_pa_raw ? "sPA✗f" : ""
    _lbl = _t + (str.length(_pa_l) > 0 ? "|" + _pa_l : "") + (str.length(_pa_s) > 0 ? "|" + _pa_s : "")
    _col = trend == 1 ? color.new(color.teal, 40) : trend == -1 ? color.new(color.red, 40) : color.new(color.gray, 60)
    label.new(bar_index, high, _lbl, style=label.style_label_down, color=_col, textcolor=color.white, size=size.tiny)

// Debug Background
bgcolor(longCondition  ? color.new(color.green, 80) : na, title="Debug Long")
bgcolor(shortCondition ? color.new(color.red,   80) : na, title="Debug Short")

// ==========================================
// Debug Table — แสดงสาเหตุที่ติดอยู่บนกราฟแบบ real-time
// ==========================================
var table dbg_tbl = table.new(position.top_right, 3, 14,
     bgcolor      = color.new(color.black, 15),
     border_width = 1,
     border_color = color.new(color.gray, 50))

c_ok  = color.new(color.teal,   20)
c_no  = color.new(color.red,    20)
c_hdr = color.new(color.navy,   20)
c_na  = color.new(color.gray,   50)

if show_debug and barstate.islast
    table.cell(dbg_tbl, 0, 0, "Condition",       bgcolor=c_hdr, text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 1, 0, "LONG",            bgcolor=c_hdr, text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 0, "SHORT",           bgcolor=c_hdr, text_color=color.white, text_size=size.small)

    // Trend
    table.cell(dbg_tbl, 0, 1, "Trend",           bgcolor=c_na,  text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 1, 1, trend == 1  ? "✓ Bull" : str.tostring(trend), bgcolor=(trend == 1  ? c_ok : c_no), text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 1, trend == -1 ? "✓ Bear" : str.tostring(trend), bgcolor=(trend == -1 ? c_ok : c_no), text_color=color.white, text_size=size.small)

    // Zone
    table.cell(dbg_tbl, 0, 2, "Zone",            bgcolor=c_na,  text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 1, 2, zone_bull ? "✓ OK"  : touched_discount ? "✓ Touch" : "✗ No Touch", bgcolor=(zone_bull ? c_ok : c_no), text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 2, zone_bear ? "✓ OK"  : touched_premium  ? "✓ Touch" : "✗ No Touch", bgcolor=(zone_bear ? c_ok : c_no), text_color=color.white, text_size=size.small)

    // Bullish/Bearish PA
    table.cell(dbg_tbl, 0, 3, "PA Signal",       bgcolor=c_na,  text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 1, 3, bullish_pa ? "✓ OK" : (bullish_pa_raw ? "✗ Filter" : "✗ No PA"), bgcolor=(bullish_pa ? c_ok : c_no), text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 3, bearish_pa ? "✓ OK" : (bearish_pa_raw ? "✗ Filter" : "✗ No PA"), bgcolor=(bearish_pa ? c_ok : c_no), text_color=color.white, text_size=size.small)

    // PA filter detail (bull side)
    table.cell(dbg_tbl, 0, 4, "PA Body/Wick/Pos",bgcolor=c_na,  text_color=color.white, text_size=size.tiny)
    table.cell(dbg_tbl, 1, 4,
         str.tostring(math.round(bull_body_ratio,2)) + " / " +
         str.tostring(math.round(bull_wick_ratio,2)) + " / " +
         str.tostring(math.round(bull_close_pos,2)),
         bgcolor=c_na, text_color=color.white, text_size=size.tiny)
    table.cell(dbg_tbl, 2, 4,
         str.tostring(math.round(bear_body_ratio,2)) + " / " +
         str.tostring(math.round(bear_wick_ratio,2)) + " / " +
         str.tostring(math.round(bear_close_pos,2)),
         bgcolor=c_na, text_color=color.white, text_size=size.tiny)

    // EMA
    table.cell(dbg_tbl, 0, 5, "EMA 200",         bgcolor=c_na,  text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 1, 5, ema_long_cond  ? "✓ Above" : "✗ Below", bgcolor=(ema_long_cond  ? c_ok : c_no), text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 5, ema_short_cond ? "✓ Below" : "✗ Above", bgcolor=(ema_short_cond ? c_ok : c_no), text_color=color.white, text_size=size.small)

    // CHoCH block
    table.cell(dbg_tbl, 0, 6, "CHoCH Block",     bgcolor=c_na,  text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 1, 6, choch_bear ? "⚠ BLOCKING" : "✓ Clear", bgcolor=(choch_bear ? c_no : c_ok), text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 6, choch_bull ? "⚠ BLOCKING" : "✓ Clear", bgcolor=(choch_bull ? c_no : c_ok), text_color=color.white, text_size=size.small)

    // Pending BOS block
    table.cell(dbg_tbl, 0, 7, "Pend.BOS Block",  bgcolor=c_na,  text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 1, 7, pending_bos_bear ? "⚠ Bear Pend" : "✓ Clear", bgcolor=(pending_bos_bear ? c_no : c_ok), text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 7, pending_bos_bull ? "⚠ Bull Pend" : "✓ Clear", bgcolor=(pending_bos_bull ? c_no : c_ok), text_color=color.white, text_size=size.small)

    // News/Vol filter
    table.cell(dbg_tbl, 0, 8, "Filter Block",    bgcolor=c_na,  text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 1, 8, filter_blocked ? "⚠ NEWS/VOL" : "✓ Clear", bgcolor=(filter_blocked ? c_no : c_ok), text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 8, filter_blocked ? "⚠ NEWS/VOL" : "✓ Clear", bgcolor=(filter_blocked ? c_no : c_ok), text_color=color.white, text_size=size.small)

    // Sideway Filter (ADX/CHOP/ATR)
    table.cell(dbg_tbl, 0, 9, "Sideway Block",   bgcolor=c_na,  text_color=color.white, text_size=size.small)
    _sw_lbl = sideway_blocked ? "⚠ SIDEWAY (" + f_n(adx_val) + ")" : "✓ Clear (" + f_n(adx_val) + ")"
    table.cell(dbg_tbl, 1, 9, _sw_lbl, bgcolor=(sideway_blocked ? c_no : c_ok), text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 9, _sw_lbl, bgcolor=(sideway_blocked ? c_no : c_ok), text_color=color.white, text_size=size.small)

    // Swing info
    table.cell(dbg_tbl, 0, 10, "Swing H/L",       bgcolor=c_na,  text_color=color.white, text_size=size.tiny)
    table.cell(dbg_tbl, 1, 10, str.tostring(math.round(swing_high,2)) + " / " + str.tostring(math.round(swing_low,2)), bgcolor=c_na, text_color=color.white, text_size=size.tiny)
    table.cell(dbg_tbl, 2, 10, "Disc:" + str.tostring(math.round(discount_level,2)) + " Prem:" + str.tostring(math.round(premium_level,2)), bgcolor=c_na, text_color=color.white, text_size=size.tiny)

    // EMA value
    table.cell(dbg_tbl, 0, 11, "EMA200 val",      bgcolor=c_na,  text_color=color.white, text_size=size.tiny)
    table.cell(dbg_tbl, 1, 11, str.tostring(math.round(ema_line,2)), bgcolor=c_na, text_color=color.white, text_size=size.tiny)
    table.cell(dbg_tbl, 2, 11, "Close: " + str.tostring(math.round(close,2)),        bgcolor=c_na, text_color=color.white, text_size=size.tiny)

    // Final result
    table.cell(dbg_tbl, 0, 12, "=== READY ===",   bgcolor=c_hdr, text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 1, 12, longCondition  ? "🟢 LONG FIRE!"  : "🔴 NO ENTRY", bgcolor=(longCondition  ? c_ok : c_no), text_color=color.white, text_size=size.small)
    table.cell(dbg_tbl, 2, 12, shortCondition ? "🟢 SHORT FIRE!" : "🔴 NO ENTRY", bgcolor=(shortCondition ? c_ok : c_no), text_color=color.white, text_size=size.small)

    // CHoCH bar remaining
    int bear_remaining = choch_bear ? choch_max_bars - (bar_index - choch_bear_bar) : 0
    int bull_remaining = choch_bull ? choch_max_bars - (bar_index - choch_bull_bar) : 0
    table.cell(dbg_tbl, 0, 13, "CHoCH Expire",    bgcolor=c_na,  text_color=color.white, text_size=size.tiny)
    table.cell(dbg_tbl, 1, 13, choch_bear ? "⏳ " + str.tostring(bear_remaining) + " bars left" : "-", bgcolor=(choch_bear ? c_no : c_na), text_color=color.white, text_size=size.tiny)
    table.cell(dbg_tbl, 2, 13, choch_bull ? "⏳ " + str.tostring(bull_remaining) + " bars left" : "-", bgcolor=(choch_bull ? c_no : c_na), text_color=color.white, text_size=size.tiny)

// ==========================================
// Execution & Risk Management
// ==========================================
// Execution & Risk Management
// ==========================================
var float  t_entry_long  = na
var float  t_sl_long     = na
var float  t_tp_long     = na
var float  t_entry_short = na
var float  t_sl_short    = na
var float  t_tp_short    = na
var string sid_long      = na
var string sid_short     = na

pos_closed_long  = strategy.position_size <= 0 and strategy.position_size[1] > 0
pos_closed_short = strategy.position_size >= 0 and strategy.position_size[1] < 0

is_entering_long  = false
is_entering_short = false

// TP/BE distances in price
tp_val  = tp_pips  * syminfo.mintick
be_val  = be_pips  * syminfo.mintick
t1_val  = trail1_pips * syminfo.mintick
lk_val  = lock1_pips  * syminfo.mintick

// Minimum valid order quantity for TradingView symbol (prevents silent rejection when mincontract > fixed_lot)
calc_qty = math.max(fixed_lot, syminfo.mincontract)

// ==========================================
// [TEST MODE] Bare-minimum entry — โดยไม่ผ่าน risk check, ไม่มี function call
// ==========================================
if test_mode
    _sl_offset = 50 * syminfo.mintick * 100  // $50 offset
    _tp_offset = 200 * syminfo.mintick * 100 // $200 offset
    if longCondition
        strategy.entry("Buy", strategy.long,  qty=calc_qty)
        strategy.exit("XBuy",  "Buy",  stop=close - _sl_offset, limit=close + _tp_offset)
    if shortCondition
        strategy.entry("Sell", strategy.short, qty=calc_qty)
        strategy.exit("XSell", "Sell", stop=close + _sl_offset, limit=close - _tp_offset)

if longCondition
    sl_price   = use_fixed_sl ? (close - (fixed_sl_pips * syminfo.mintick)) : (nz(swing_low, close - (max_sl_pips * syminfo.mintick)) - sl_buffer)
    risk       = close - sl_price
    max_sl_val = max_sl_pips * syminfo.mintick
    if not use_fixed_sl and (na(risk) or risk > max_sl_val or risk <= 0)
        risk     := max_sl_val
        sl_price := close - max_sl_val
    if risk > 0
        tp_price         = close + tp_val
        strategy.entry("Buy", strategy.long, qty=calc_qty)
        t_entry_long     := close
        t_sl_long        := sl_price
        t_tp_long        := tp_price
        s                = str.tostring(time) + "_BUY"
        sid_long         := s
        is_entering_long := true
        zone_tag         = in_bull_fvg ? "FVG" : in_bull_ob ? "OB" : "PD"
        alert(f_open("BUY", close, sl_price, tp_price, s, calc_qty, be_pips, trail1_pips, lock1_pips, tp_pips), alert.freq_once_per_bar_close)

if shortCondition
    sl_price   = use_fixed_sl ? (close + (fixed_sl_pips * syminfo.mintick)) : (nz(swing_high, close + (max_sl_pips * syminfo.mintick)) + sl_buffer)
    risk       = sl_price - close
    max_sl_val = max_sl_pips * syminfo.mintick
    if not use_fixed_sl and (na(risk) or risk > max_sl_val or risk <= 0)
        risk     := max_sl_val
        sl_price := close + max_sl_val
    if risk > 0
        tp_price          = close - tp_val
        strategy.entry("Sell", strategy.short, qty=calc_qty)
        t_entry_short     := close
        t_sl_short        := sl_price
        t_tp_short        := tp_price
        s                 = str.tostring(time) + "_SELL"
        sid_short         := s
        is_entering_short := true
        alert(f_open("SELL", close, sl_price, tp_price, s, calc_qty, be_pips, trail1_pips, lock1_pips, tp_pips), alert.freq_once_per_bar_close)

// ==========================================
// Scaled Breakeven & Trailing
// Level1: profit >= be_pips  -> SL = entry
// Level2: profit >= trail1_pips -> SL = entry + lock1_pips
// ==========================================
var float max_price = na
var float min_price = na

if strategy.position_size == 0
    max_price := na
    min_price := na

if strategy.position_size > 0
    max_price  := na(max_price) ? high : math.max(max_price, high)
    ep          = strategy.position_avg_price
    profit_d    = max_price - ep
    new_sl = t_sl_long
    if profit_d >= t1_val
        locked  = ep + lk_val
        new_sl := na(new_sl) ? locked : math.max(new_sl, locked)
    else if profit_d >= be_val
        be_locked = ep + (10 * syminfo.mintick)  // Offset 10 pips to cover commission/slippage so it's not a loss
        new_sl := na(new_sl) ? be_locked : math.max(new_sl, be_locked)
    t_sl_long  := new_sl

if strategy.position_size < 0
    min_price  := na(min_price) ? low : math.min(min_price, low)
    ep          = strategy.position_avg_price
    profit_d    = ep - min_price
    new_sl = t_sl_short
    if profit_d >= t1_val
        locked  = ep - lk_val
        new_sl := na(new_sl) ? locked : math.min(new_sl, locked)
    else if profit_d >= be_val
        be_locked = ep - (10 * syminfo.mintick)  // Offset 10 pips to cover commission/slippage
        new_sl := na(new_sl) ? be_locked : math.min(new_sl, be_locked)
    t_sl_short := new_sl

// ==========================================
// Exits (Hard TP at 1500pip + dynamic SL)
// ==========================================
if strategy.position_size > 0 and not na(t_sl_long) and not na(t_tp_long)
    strategy.exit("Exit Buy", "Buy", stop=t_sl_long, limit=t_tp_long)

if strategy.position_size < 0 and not na(t_sl_short) and not na(t_tp_short)
    strategy.exit("Exit Sell", "Sell", stop=t_sl_short, limit=t_tp_short)

if pos_closed_long and not is_entering_long
    t_entry_long  := na
    t_sl_long     := na
    t_tp_long     := na
    sid_long      := na

if pos_closed_short and not is_entering_short
    t_entry_short := na
    t_sl_short    := na
    t_tp_short    := na
    sid_short     := na

// ==========================================
// Close alert
// ==========================================
if strategy.closedtrades > nz(strategy.closedtrades[1], 0)
    idx    = strategy.closedtrades - 1
    pnl    = strategy.closedtrades.profit(idx)
    res    = pnl > 0 ? "WIN" : "LOSS"
    ep     = strategy.closedtrades.entry_price(idx)
    xp     = strategy.closedtrades.exit_price(idx)
    is_lng = strategy.closedtrades.size(idx) > 0
    fb     = str.tostring(time) + "_CLOSE"
    cid    = is_lng ? (na(sid_long) ? fb : sid_long) : (na(sid_short) ? fb : sid_short)
    alert(f_close(cid, ep, xp, pnl, res), alert.freq_once_per_bar_close)

// ==========================================
// Visuals: Premium/Discount zones
// ==========================================
var box pd_box = na
var box pm_box = na
if barstate.islast and not na(swing_high) and not na(swing_low)
    if not na(pd_box)
        box.delete(pd_box)
    if not na(pm_box)
        box.delete(pm_box)
    pd_box := box.new(bar_index-50, discount_level, bar_index+10, swing_low, bgcolor=color.new(color.green,90), border_color=color.new(color.green,60))
    pm_box := box.new(bar_index-50, swing_high, bar_index+10, premium_level, bgcolor=color.new(color.red,90), border_color=color.new(color.red,60))
