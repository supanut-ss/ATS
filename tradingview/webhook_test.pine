//@version=6
indicator("ATS Webhook Test", shorttitle="ATS Test", overlay=true)

// ── วิธีใช้ ──
// 1. Add to chart
// 2. สร้าง Alert → เลือก Condition อย่างใดอย่างหนึ่ง:
//    A) "🔬 Fire Test BUY"  (JSON มี {{close}} อัตโนมัติ)
//    B) "Any alert() function call only"  (JSON เต็มจาก script)
// 3. ติ๊ก Webhook URL → https://ats.thaipesleague.com/webhook
// 4. เปลี่ยน "Fire counter" จาก 0 เป็น 1

grp = "Webhook Test"

webhook_token = input.string("ats_sec_9f5c4b8e2a1d7f0e3c6b8a9f", "Webhook Token", group=grp, tooltip="ใช้กับ alert() เท่านั้น — alertcondition ใช้ token ค่า default ใน script")
fire_n        = input.int(0, "Fire counter (0→1→2 เพื่อยิง)", minval=0, group=grp)

fire = barstate.islast and fire_n > 0

// alertcondition ต้องใช้ const string — ใช้ placeholder {{close}} {{interval}} ของ TradingView
alertcondition(fire, title="🔬 Fire Test BUY", message='{"token":"ats_sec_9f5c4b8e2a1d7f0e3c6b8a9f","action":"BUY","symbol":"XAUUSD","signal_id":"tv_test","entry_price":{{close}},"sl":0,"tp":0,"timeframe":"{{interval}}","comment":"Webhook Test"}')

// alert() ส่ง JSON เต็ม (ต้องสร้าง Alert แบบ "Any alert() function call only")
if fire
    payload = '{"token":"' + webhook_token + '","action":"BUY","symbol":"XAUUSD","signal_id":"' + str.tostring(time) + '_TEST","entry_price":' + str.tostring(close, "#.##") + ',"sl":' + str.tostring(close - 10, "#.##") + ',"tp":' + str.tostring(close + 20, "#.##") + ',"rr":2,"timeframe":"' + timeframe.period + '","bar_time":' + str.tostring(time) + ',"comment":"Webhook Test"}'
    alert(payload, alert.freq_once_per_bar)

plotshape(fire, "Fired", shape.labelup, location.belowbar, color=color.lime, text="SENT", textcolor=color.white, size=size.small)

var table t = table.new(position.bottom_right, 1, 3)
if barstate.islast
    table.cell(t, 0, 0, "ATS Webhook Test", text_color=color.white, bgcolor=color.new(color.blue, 30))
    table.cell(t, 0, 1, fire ? "✓ ยิงแล้ว!" : "เปลี่ยน Fire counter", text_color=fire ? color.lime : color.gray, bgcolor=color.new(color.black, 50))
    table.cell(t, 0, 2, "Alert: Fire Test BUY", text_color=color.yellow, bgcolor=color.new(color.black, 50), text_size=size.tiny)
