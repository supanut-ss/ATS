//@version=5
strategy(
    title        = "XAUUSD — Liquidity Sweep & Volume Confirmation",
    shorttitle   = "LS+Vol Bot",
    overlay      = true,
    calc_on_every_tick = false,
    default_qty_type   = strategy.fixed,
    default_qty_value  = 0.05,
    commission_type    = strategy.commission.cash_per_contract,
    commission_value   = 0.35,
    slippage           = 3
)

// ══════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════
grp_tf       = "⏱ Timeframes"
grp_liq      = "💧 Liquidity"
grp_vol      = "📊 Volume"
grp_sl       = "🛡 Risk / SL / TP"
grp_wh       = "🔗 Webhook"

// Liquidity Pool Settings
eqh_lookback = input.int(20, "EQH/EQL Lookback (bars)",          group=grp_liq, minval=5)
eq_tolerance = input.float(0.5, "EQ Tolerance (USD)",             group=grp_liq, minval=0.1, step=0.1)
show_liq     = input.bool(true, "Show Liquidity Zones",           group=grp_liq)

// Volume Settings
vol_ma_len   = input.int(20, "Volume MA Length",                  group=grp_vol)
vol_mult     = input.float(1.5, "Volume Spike Multiplier (×MA)",  group=grp_vol, minval=1.0, step=0.1)

// MSS / ChoCh Settings
mss_lookback = input.int(5, "MSS Structure Lookback",             group=grp_liq)

// SL / TP
sl_buffer    = input.float(2.0, "SL Buffer above/below Sweep (USD)", group=grp_sl, minval=0.1)
tp_rr        = input.float(2.0, "Take Profit R:R Ratio",          group=grp_sl, minval=0.5, step=0.5)

// Webhook Token (must match your .env WEBHOOK_SECRET)
webhook_token = input.string("your_secret_token_here", "Webhook Auth Token", group=grp_wh)
webhook_url   = input.string("http://localhost:5000/webhook", "Webhook URL",  group=grp_wh)

// ══════════════════════════════════════════════════════════
// VOLUME ANALYSIS
// ══════════════════════════════════════════════════════════
vol_ma    = ta.sma(volume, vol_ma_len)
vol_spike = volume > vol_ma * vol_mult

// ══════════════════════════════════════════════════════════
// EQUAL HIGHS / EQUAL LOWS (Liquidity Pools)
// ══════════════════════════════════════════════════════════
ph = ta.pivothigh(high, eqh_lookback, eqh_lookback)
pl = ta.pivotlow(low,  eqh_lookback, eqh_lookback)

// Store recent pivot high and low for EQH/EQL detection
var float last_ph = na
var float last_pl = na
var int   last_ph_bar = na
var int   last_pl_bar = na

if not na(ph)
    if not na(last_ph) and math.abs(ph - last_ph) <= eq_tolerance
        // Equal Highs detected — mark as EQH liquidity
        if show_liq
            line.new(last_ph_bar, last_ph, bar_index - eqh_lookback, ph, color=color.new(color.red, 40), width=1, style=line.style_dashed)
    last_ph     := ph
    last_ph_bar := bar_index - eqh_lookback

if not na(pl)
    if not na(last_pl) and math.abs(pl - last_pl) <= eq_tolerance
        // Equal Lows detected — mark as EQL liquidity
        if show_liq
            line.new(last_pl_bar, last_pl, bar_index - eqh_lookback, pl, color=color.new(color.lime, 40), width=1, style=line.style_dashed)
    last_pl     := pl
    last_pl_bar := bar_index - eqh_lookback

// ══════════════════════════════════════════════════════════
// LIQUIDITY SWEEP DETECTION
// ══════════════════════════════════════════════════════════
// Sweep High: wick pierces above recent high but closes below it (bearish sweep)
// Sweep Low:  wick pierces below recent low but closes above it (bullish sweep)
recent_high = ta.highest(high, eqh_lookback)
recent_low  = ta.lowest(low,   eqh_lookback)

swept_high = high > recent_high[1] and close < recent_high[1]  // stop hunt above highs
swept_low  = low  < recent_low[1]  and close > recent_low[1]   // stop hunt below lows

plotshape(swept_high, "Sweep High", shape.triangledown, location.abovebar, color.new(color.red,  20), size=size.small)
plotshape(swept_low,  "Sweep Low",  shape.triangleup,   location.belowbar, color.new(color.lime, 20), size=size.small)

// ══════════════════════════════════════════════════════════
// MARKET STRUCTURE SHIFT (MSS / ChoCh)
// ══════════════════════════════════════════════════════════
// After bullish sweep: MSS = price breaks above the last swing high (ChoCh bullish)
// After bearish sweep: MSS = price breaks below the last swing low (ChoCh bearish)

swing_hi = ta.highest(high, mss_lookback)
swing_lo = ta.lowest(low,   mss_lookback)

// MSS Bullish: broke above swing high after a sweep low
mss_bull = close > swing_hi[1] and swept_low[1]
// MSS Bearish: broke below swing low after a sweep high
mss_bear = close < swing_lo[1] and swept_high[1]

plotshape(mss_bull, "MSS Bull", shape.labelup,   location.belowbar, color.new(color.teal,   10), text="MSS↑", textcolor=color.white, size=size.tiny)
plotshape(mss_bear, "MSS Bear", shape.labeldown, location.abovebar, color.new(color.orange, 10), text="MSS↓", textcolor=color.white, size=size.tiny)

// ══════════════════════════════════════════════════════════
// FAIR VALUE GAP (FVG) Detection
// ══════════════════════════════════════════════════════════
// Bullish FVG: gap between candle[2] high and candle[0] low
// Bearish FVG: gap between candle[2] low and candle[0] high
fvg_bull_top    = high[2]
fvg_bull_bot    = low[0]
fvg_bull_exists = fvg_bull_bot > fvg_bull_top

fvg_bear_top    = high[0]
fvg_bear_bot    = low[2]
fvg_bear_exists = fvg_bear_bot > fvg_bear_top

bgcolor(fvg_bull_exists and show_liq ? color.new(color.teal,  90) : na, title="Bullish FVG")
bgcolor(fvg_bear_exists and show_liq ? color.new(color.orange,90) : na, title="Bearish FVG")

// ══════════════════════════════════════════════════════════
// ENTRY SIGNALS (Full Confluence Required)
// Checklist:
//   ✓ Sweep of EQH/EQL
//   ✓ MSS / ChoCh in opposite direction
//   ✓ Volume confirmation (spike on MSS candle)
// ══════════════════════════════════════════════════════════
long_signal  = swept_low[1]  and mss_bull and vol_spike
short_signal = swept_high[1] and mss_bear and vol_spike

// ══════════════════════════════════════════════════════════
// STOP LOSS & TAKE PROFIT CALCULATION
// ══════════════════════════════════════════════════════════
long_sl  = ta.lowest(low, 3) - sl_buffer
short_sl = ta.highest(high, 3) + sl_buffer

long_sl_dist  = close - long_sl
short_sl_dist = short_sl - close

long_tp  = close + long_sl_dist  * tp_rr
short_tp = close - short_sl_dist * tp_rr

// ══════════════════════════════════════════════════════════
// STRATEGY ENTRIES (for backtesting)
// ══════════════════════════════════════════════════════════
if long_signal
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=long_sl, limit=long_tp)

if short_signal
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=short_sl, limit=short_tp)

// ══════════════════════════════════════════════════════════
// ALERTS (Webhook → Python Bot → MT5)
// ══════════════════════════════════════════════════════════
// BUY Alert
if long_signal
    alert(
        '{"token":"' + webhook_token + '","action":"BUY","symbol":"XAUUSD",' +
        '"sl":' + str.tostring(math.round(long_sl, 2)) + ',' +
        '"tp":' + str.tostring(math.round(long_tp, 2)) + ',' +
        '"comment":"Sweep+MSS+Vol BUY"}',
        alert.freq_once_per_bar_close
    )

// SELL Alert
if short_signal
    alert(
        '{"token":"' + webhook_token + '","action":"SELL","symbol":"XAUUSD",' +
        '"sl":' + str.tostring(math.round(short_sl, 2)) + ',' +
        '"tp":' + str.tostring(math.round(short_tp, 2)) + ',' +
        '"comment":"Sweep+MSS+Vol SELL"}',
        alert.freq_once_per_bar_close
    )

// ══════════════════════════════════════════════════════════
// VISUAL: Entry Markers
// ══════════════════════════════════════════════════════════
plotshape(long_signal,  "BUY Signal",  shape.arrowup,   location.belowbar, color.new(color.green, 0), size=size.normal)
plotshape(short_signal, "SELL Signal", shape.arrowdown, location.abovebar, color.new(color.red,   0), size=size.normal)

// Volume bars coloring
barcolor(vol_spike and long_signal  ? color.new(color.green, 30) :
         vol_spike and short_signal ? color.new(color.red,   30) : na)

// ══════════════════════════════════════════════════════════
// INFO TABLE (Top-Right)
// ══════════════════════════════════════════════════════════
var table info_tbl = table.new(position.top_right, 2, 6, border_width=1)
if barstate.islast
    table.cell(info_tbl, 0, 0, "XAUUSD Bot",    text_color=color.white,  bgcolor=color.new(color.blue, 20),  text_size=size.small, text_halign=text.align_center)
    table.cell(info_tbl, 1, 0, "Liquidity Sweep",text_color=color.white, bgcolor=color.new(color.blue, 20),  text_size=size.small, text_halign=text.align_center)
    table.cell(info_tbl, 0, 1, "Vol MA",         text_color=color.gray,  bgcolor=color.new(color.black, 50), text_size=size.tiny)
    table.cell(info_tbl, 1, 1, str.tostring(math.round(vol_ma, 0)), text_color=color.white, bgcolor=color.new(color.black, 50), text_size=size.tiny)
    table.cell(info_tbl, 0, 2, "Vol Spike",      text_color=color.gray,  bgcolor=color.new(color.black, 50), text_size=size.tiny)
    table.cell(info_tbl, 1, 2, vol_spike ? "YES ✓" : "no", text_color=vol_spike ? color.lime : color.gray, bgcolor=color.new(color.black, 50), text_size=size.tiny)
    table.cell(info_tbl, 0, 3, "Swept High",     text_color=color.gray,  bgcolor=color.new(color.black, 50), text_size=size.tiny)
    table.cell(info_tbl, 1, 3, swept_high ? "YES ✓" : "no", text_color=swept_high ? color.red : color.gray, bgcolor=color.new(color.black, 50), text_size=size.tiny)
    table.cell(info_tbl, 0, 4, "Swept Low",      text_color=color.gray,  bgcolor=color.new(color.black, 50), text_size=size.tiny)
    table.cell(info_tbl, 1, 4, swept_low ? "YES ✓" : "no", text_color=swept_low ? color.lime : color.gray, bgcolor=color.new(color.black, 50), text_size=size.tiny)
    table.cell(info_tbl, 0, 5, "SL Buffer",      text_color=color.gray,  bgcolor=color.new(color.black, 50), text_size=size.tiny)
    table.cell(info_tbl, 1, 5, str.tostring(sl_buffer) + " USD", text_color=color.white, bgcolor=color.new(color.black, 50), text_size=size.tiny)
