# Environment Variables — Copy this to .env and fill in your values
# DO NOT commit .env to Git!

# ──────────────────────────────────────────────
# MT5 Account (Exness Demo)
# ──────────────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=YourPassword
MT5_SERVER=Exness-MT5Trial

# ──────────────────────────────────────────────
# Trading Settings
# ──────────────────────────────────────────────
FIXED_LOT=0.05
MAX_POSITIONS=3
MAX_DAILY_LOSS_USD=100

# ──────────────────────────────────────────────
# Webhook Security Token
# (ใส่ใน TradingView alert URL: /webhook?token=YOUR_TOKEN)
# ──────────────────────────────────────────────
WEBHOOK_SECRET=your_secret_token_here

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=false
